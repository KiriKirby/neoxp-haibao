[
  {
    "label": "NeoXP: Install",
    "command": "npm",
    "args": ["install"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Dev",
    "command": "powershell",
    "args": [
      "-NoProfile",
      "-ExecutionPolicy",
      "Bypass",
      "-File",
      "$ZED_WORKTREE_ROOT/scripts/dev.ps1",
      "-SkipInstall",
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Dev Inspect Main",
    "command": "powershell",
    "args": [
      "-NoProfile",
      "-ExecutionPolicy",
      "Bypass",
      "-File",
      "$ZED_WORKTREE_ROOT/scripts/dev.ps1",
      "-SkipInstall",
      "-InspectMain",
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Build",
    "command": "npm",
    "args": ["run", "build"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Build Debug Desktop",
    "command": "npm",
    "args": ["run", "build:debug"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Typecheck",
    "command": "npm",
    "args": ["run", "typecheck"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Test",
    "command": "npm",
    "args": ["run", "test"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
  {
    "label": "NeoXP: Preview",
    "command": "npm",
    "args": ["run", "preview", "--workspace=@neoxp/desktop"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "hide": "never",
  },
]
